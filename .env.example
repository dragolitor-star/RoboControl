# --------------------------------------------------------------------------- #
# RCS-2000 Middleware — Environment Variables Example
# Copy to `.env` and fill in real values for your environment.
# --------------------------------------------------------------------------- #

# Application identity
APP_NAME=rcs-middleware                # Human-readable service name
APP_ENV=dev                            # dev | staging | prod
DEBUG=true                             # MUST be false when APP_ENV=prod (validator-enforced)
LOG_LEVEL=INFO                         # Standard Python logging level

# Database (async DSN — aiomysql driver)
MYSQL_URL=mysql+aiomysql://rcs:rcs@localhost:3306/rcs_middleware

# Redis (state cache + idempotency + Celery broker default)
REDIS_URL=redis://localhost:6379/0

# RCS-2000 upstream (UD41427B_RCS-2000 API Developer Guide_V4.3.0)
# - X-lr-appkey: 32-char app key issued by scheduling system
# - X-lr-version: document examples use "v1.0"
# - RCS default connection timeout threshold: 30s
RCS_BASE_URL=http://10.10.10.10:1010    # Replace with your actual RCS host:port
RCS_APP_KEY=replace-with-32-char-appkey
RCS_APP_SECRET=replace-with-app-secret
RCS_API_VERSION=v1.0
RCS_TIMEOUT=30.0

# Celery (defaults to REDIS_URL if blank)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# API security
API_KEY=test-api-key               # Clients send X-API-Key
WEBHOOK_SECRET=test-webhook-secret        # HMAC-SHA256 secret for X-Webhook-Signature

# CORS — comma-separated list of allowed origins; "*" allows all
CORS_ORIGINS=["*"]

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
